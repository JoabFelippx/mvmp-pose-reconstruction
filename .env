# IS-Wire / RabbitMQ
BROKER_URI=amqp://guest:guest@10.10.2.211:30000

# Câmeras
NUM_CAMERAS=4
CALIB_PATH=calibrations/calib_rt   # prefixo; resultado: calib_rt1.npz, calib_rt2.npz ...
USE_UNDISTORTED=true
APPLY_UNDISTORT=true

# Keypoints
NUM_KEYPOINTS=18

# Matcher — só altere se quiser tunar sem rebuildar
MATCHER_USE_CYCLE_CONSISTENCY=true
MATCHER_SIGMA_TOLERANCE=15.0
MATCHER_MAX_ERROR_PER_JOINT=20.0
MATCHER_WEIGHT_QUALITY=0.7
MATCHER_WEIGHT_QUANTITY=0.3
MATCHER_MIN_COMPATIBILITY_SCORE=0.3
MATCHER_TOP_K_CYCLE_CANDIDATES=3
MATCHER_EARLY_STOP_CYCLE_SCORE=0.7
MATCHER_WEIGHT_CYCLE=0.5
MATCHER_MIN_CYCLE_SCORE=0.50
MATCHER_MAX_INTERSECTION_DIST=3.0
MATCHER_WEIGHT_DISTANCE=0.60
MATCHER_WEIGHT_SCORE=0.40
MATCHER_MIN_KEYPOINTS_FOR_GROUPING=10
MATCHER_MIN_KP_RATIO=0.30
MATCHER_MIN_FALLBACK_SCORE=0.78
